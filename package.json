{
  "name": "ouro-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/cli",
    "packages/dashboard"
  ],
  "scripts": {
    "build:dashboard": "npm run build --workspace=packages/dashboard",
    "dev:dashboard": "npm run dev --workspace=packages/dashboard",
    "bundle": "npm run build:dashboard && node scripts/bundle-dashboard.js",
    "link:cli": "npm link --workspace=packages/cli",
    "lint": "eslint .",
    "test": "node --test packages/cli/test/*.test.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0"
  }
}
